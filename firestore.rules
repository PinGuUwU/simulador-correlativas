rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función para verificar si el usuario es dueño del documento
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Colección de Usuarios: Solo el dueño puede leer y escribir
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Colección de Roles: 
    // Los usuarios solo pueden leer su propio rol.
    // Solo admins (o vía Firebase Console/Backend) pueden escribir.
    match /roles/{userId} {
      allow read: if isOwner(userId);
      allow write: if false; // Solo manual o via admin SDK
    }

    // Otras colecciones...
  }
}
